# GraceChords environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Supabase project credentials
# Find these in your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required for Node build scripts (generate-seo-pages.mjs, generate-sitemap.mjs)
# Find this in your Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Legacy admin gate (used by ingest CLI scripts)
VITE_ADMIN_PW=your-password

# Set to 0 to disable footer/PDF disclaimers
VITE_ENABLE_DISCLAIMER=1

# Optional contact line shown in disclaimers
VITE_CONTACT_EMAIL=you@example.com

# PPTX Upload Worker
# The deployed URL of the gracechords-pptx-upload Cloudflare Worker.
# Example: https://gracechords-pptx-upload.your-subdomain.workers.dev
# See workers/pptx-upload/README.md for setup instructions.
VITE_PPTX_WORKER_URL=https://gracechords-pptx-upload.your-subdomain.workers.dev

# Bible CDN
# Public CDN base URL for Bible text assets (JSON files served via jsDelivr or similar).
# Example: https://pub-<hash>.r2.dev  or  https://cdn.jsdelivr.net/gh/your-org/bible-data
VITE_BIBLE_CDN_URL=https://your-bible-cdn-url.example.com

# Cloudinary (image hosting)
# Find these in your Cloudinary dashboard → Settings → API Keys
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# The unsigned upload preset to use for media uploads (Cloudinary → Settings → Upload → Upload presets)
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
