# GraceChords environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Supabase project credentials
# Find these in your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required for Node build scripts (generate-seo-pages.mjs, generate-sitemap.mjs)
# Find this in your Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set to 0 to disable footer/PDF disclaimers
VITE_ENABLE_DISCLAIMER=1

# Optional contact line shown in disclaimers
VITE_CONTACT_EMAIL=you@example.com

# PPTX Upload Worker
# The deployed URL of the gracechords-pptx-upload Cloudflare Worker.
# Example: https://gracechords-pptx-upload.your-subdomain.workers.dev
# See workers/pptx-upload/README.md for setup instructions.
VITE_PPTX_WORKER_URL=https://gracechords-pptx-upload.your-subdomain.workers.dev

# R2 Public URL
# Base URL for all Cloudflare R2 assets (Bible JSON under /bible/, PPTX slides under /pptx/).
VITE_R2_PUBLIC_URL=https://assets.gracechords.com

# Telegram "Push to Telegram" — server-side only (Pages Functions).
# Pages Function /api/telegram/push forwards to the bot Worker's
# /internal/push endpoint. Both values must match the bot Worker.
# Set in Cloudflare Pages → Settings → Variables. Do not prefix with VITE_.
#   BOT_INTERNAL_URL  — public URL of the gracechords-telegram-bot Worker
#                       (e.g. https://gracechords-telegram-bot.<acct>.workers.dev)
#   BOT_WEBHOOK_TOKEN — shared secret; same value is set on the bot Worker
#                       via `wrangler secret put BOT_WEBHOOK_TOKEN`.
BOT_INTERNAL_URL=https://gracechords-telegram-bot.your-subdomain.workers.dev
BOT_WEBHOOK_TOKEN=your-shared-bot-webhook-token

# Public-reflections moderation — server-side only (Pages Function
# /api/reflections/submit). OpenAI Moderation (omni-moderation-latest) is Layer 2
# of the moderation pipeline; Layer 1 is a local blocklist/URL/length check.
# Set in Cloudflare Pages → Settings → Variables as an encrypted secret. Do NOT
# prefix with VITE_ — it must never reach the client bundle.
# The report endpoint (/api/reflections/report) reuses BOT_INTERNAL_URL +
# BOT_WEBHOOK_TOKEN above to fire the admin Telegram alert.
OPENAI_API_KEY=your-openai-api-key

# Cloudinary (image hosting)
# Find these in your Cloudinary dashboard → Settings → API Keys
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# The unsigned upload preset to use for media uploads (Cloudinary → Settings → Upload → Upload presets)
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
