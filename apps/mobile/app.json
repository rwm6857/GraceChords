{
  "expo": {
    "name": "GraceChords",
    "slug": "gracechords",
    "scheme": "gracechords",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.gracechords.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.gracechords.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F7F9",
          "dark": { "backgroundColor": "#14171A" }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
