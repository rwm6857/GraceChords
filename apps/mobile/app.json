{
  "expo": {
    "name": "GraceChords",
    "slug": "gracechords",
    "scheme": "gracechords",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.gracechords.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gracechords.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F7F9",
          "dark": {
            "backgroundColor": "#14171A"
          }
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.153438056905-ds29ptotnqkiq9bmpkqrbnlrrek3d17o"
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "GraceChords uses the microphone only for the real-time instrument tuner. Audio is analyzed on this device to detect pitch and is never recorded, stored, or transmitted.",
          "iosBackgroundMode": false,
          "androidPermissions": ["android.permission.RECORD_AUDIO"],
          "androidForegroundService": false,
          "disableFFmpeg": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3be270a3-166a-492a-a4ec-c95f442175d7"
      }
    },
    "owner": "nohoot23"
  }
}
