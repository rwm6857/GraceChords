# Copy to apps/mobile/.env and fill in. Never commit .env.
#
# These are the SAME public Supabase values the web client uses
# (VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY in apps/web). The anon key is the
# public, RLS-gated key — NOT the service-role key. Expo only exposes vars
# prefixed with EXPO_PUBLIC_ to the JS bundle.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Base URL of the deployed web app (Cloudflare Pages) — the mobile app calls
# its Pages Functions for song export (/api/export/song) and Telegram push
# (/api/telegram/push).
EXPO_PUBLIC_API_BASE_URL=https://your-web-app-domain.example
